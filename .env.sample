# ============================================
# FPS Pro Video Hub - 環境変数テンプレート
# ============================================
# セットアップ手順:
#   1. このファイルをコピーして「.env」にリネーム
#      コマンド例: cp .env.sample .env
#   2. 各APIキーの値を自分のものに書き換える
#   3. .env は .gitignore で除外されるため安全です
# ============================================

YOUTUBE_API_KEY=your_api_key_here
RAKUTEN_APP_ID=your_rakuten_app_id_here
